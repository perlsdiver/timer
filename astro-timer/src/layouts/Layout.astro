---
interface Props {
	title: string;
}

const { title } = Astro.props;

// Import all CSS files
import "../styles/main.css";
import "../styles/timer-styles.css";
import "../styles/brutalist.css";
import "../styles/dark-brutalist.css";
import "../styles/indie-cat.css";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/site-icon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<script>
			// Import scripts using Astro's script bundling
			import "../scripts/helpers.js";
			import "../scripts/timer.js";
			import "../scripts/app-init.js";
			import "../scripts/theme.js";
		</script>
	</body>
</html>

<style is:global>
	/* quick fix - controls weren't centering */
	.controls {
		display: flex; gap: 10px; justify-content: center;
		margin-top: 20px;
	}
	.controls button {
		min-width: 90px;
	}
	#mode-label {
		font-size: 14px; text-transform: uppercase;
		letter-spacing: 0.15em; color: #888; margin-bottom: 8px;
	}
</style>
