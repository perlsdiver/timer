---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frankentimer">
  <header>
    <img src="site-icon.svg" alt="Logo" class="header-logo" />
    <h1>Frankentimer</h1>
  </header>
  <main>
    <section class="card goal-card">
      <div class="goal-input-container">
        <label for="goal-input">Focusing on:</label>
        <input type="text" id="goal-input" placeholder="e.g., Coding a feature..." maxlength="50" />
      </div>
      <div id="goal-display" class="hidden">Current Goal: <span id="current-goal-text"></span></div>
    </section>
    <section class="card timer-card">
      <div class="mode-selector">
        <button id="pomodoro-btn" class="mode-btn active">Pomodoro</button>
        <button id="short-btn" class="mode-btn">Short Break</button>
        <button id="long-btn" class="mode-btn">Long Break</button>
      </div>
      <div class="timer-display" id="timer">25:00</div>
      <div class="controls">
        <button id="start-btn">Start</button>
        <button id="pause-btn" disabled>Pause</button>
        <button id="reset-btn">Reset</button>
      </div>
      <div class="settings-trigger">
        <button id="open-settings-btn" class="text-link">⚙️ Settings</button>
      </div>
    </section>
    <section class="card">
      <h2>Sessions</h2>
      <div id="session-log"><p class="empty-msg">No completed sessions yet.</p></div>
    </section>
  </main>

  <!-- Settings Modal -->
  <div id="settings-modal" class="modal hidden">
    <div class="modal-content card">
      <h3>Timer Settings</h3>
      <div class="setting-group">
        <label for="pomodoro-duration">Pomodoro (min)</label>
        <input type="number" id="pomodoro-duration" value="25" min="1" max="60" />
      </div>
      <div class="setting-group">
        <label for="short-duration">Short Break (min)</label>
        <input type="number" id="short-duration" value="5" min="1" max="30" />
      </div>
      <div class="setting-group">
        <label for="long-duration">Long Break (min)</label>
        <input type="number" id="long-duration" value="15" min="1" max="60" />
      </div>
      <div class="modal-actions">
        <button id="save-settings-btn">Save</button>
        <button id="close-settings-btn" class="secondary">Cancel</button>
      </div>
    </div>
  </div>

  <footer>
    <p>Built at a <a href="https://ailab.gc.cuny.edu/" target="_blank" rel="noopener">CUNY AI Lab workshop</a></p>
    <p>Read the <a href="https://crln.acrl.org/index.php/crlnews/article/view/26548/34482" target="_blank" rel="noopener">AI Use Disclosure Guide</a></p>
    <div class="attribution">
      <p>Features adapted from <a href="https://pomofocus.io/" target="_blank" rel="noopener">Pomofocus.io</a></p>
      <p>Audio: <a href="https://freesound.org/people/HerbertBoland/sounds/30153/" target="_blank" rel="noopener">"Bell" by HerbertBoland</a> via <a href="https://freesound.org/" target="_blank" rel="noopener">Freesound.org</a></p>
      <p>Images: <a href="https://placecats.com/" target="_blank" rel="noopener">PlaceCats.com</a>, <a href="https://picsum.photos/" target="_blank" rel="noopener">Picsum Photos</a></p>
    </div>
  </footer>
  <div class="theme-toggle-container">
    <label for="theme-select" style="font-size: 11px; margin-right: 5px; font-weight: bold;">STYLE:</label>
    <select id="theme-select">
      <option value="">Dark Minimalist</option>
      <option value="theme-brutalist">Brutalist Light</option>
      <option value="theme-dark-brutalist">Brutalist Dark</option>
      <option value="theme-indie-cat">Indieweb Cat Town</option>
      <option value="theme-random">Randomizer</option>
    </select>
  </div>
</Layout>
